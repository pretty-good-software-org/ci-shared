{
  "compilerOptions": {
    "target": "ES2023",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleDetection": "force"
  },
  "include": ["actions/**/*.ts", "lib/**/*.ts", "org-lint-config-sync/**/*.ts"],
  "exclude": ["node_modules"]
}

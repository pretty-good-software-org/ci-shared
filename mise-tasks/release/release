#!/usr/bin/env bash
#MISE description="Create a release (VERSION=x.y.z)"
set -euo pipefail

VERSION="${VERSION:?VERSION is required}"
MAJOR=$(echo "${VERSION}" | cut -d. -f1)

# git-cliff needs an authenticated token to resolve PR numbers on a private repo
export GITHUB_TOKEN="${GITHUB_TOKEN:-$(gh auth token)}"

git tag -a "v${VERSION}" -m "Release v${VERSION}"
git tag -f "v${MAJOR}" "v${VERSION}"
git push origin "v${VERSION}" "v${MAJOR}" --force
git-cliff --latest --strip header --tag "v${VERSION}" | gh release create "v${VERSION}" --title "v${VERSION}" --notes-file -
